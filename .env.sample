# ===================================
# LLM PROVIDER CONFIGURATION
# ===================================
# Options: 'local' or 'openai'
LLM_PROVIDER=local
# LLM_PROVIDER=openai
# ===================================
# MODEL SELECTION
# ===================================
# For local: granite, mistral, llama, llama-small, phi
# For openai: gpt-4.1, gpt-4.1-mini, gpt-4.1-nano
  LLM_MODEL=gemma3:1b
# LLM_MODEL=gpt-4.1-mini
# ===================================
# API KEYS
# ===================================
# OpenAI API Key (only needed if LLM_PROVIDER=openai)
# Get from: https://platform.openai.com/api-keys
# Insert your API KEY HERE
OPENAI_API_KEY= XXXXX
# ===================================